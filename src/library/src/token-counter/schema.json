{
  "$schema": "http://json-schema.org/schema",
  "$id": "PromptKitTokenCounterSchema",
  "title": "Add the token-counter component",
  "type": "object",
  "properties": {
    "project": {
      "type": "string",
      "description": "The Angular project to add the component to.",
      "$default": {
        "$source": "projectName"
      }
    },
    "path": {
      "type": "string",
      "format": "path",
      "description": "Path where the component is generated. Defaults to libs/prompt-kit."
    }
  },
  "required": []
}
