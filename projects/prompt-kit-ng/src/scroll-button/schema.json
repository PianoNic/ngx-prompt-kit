{
  "$schema": "http://json-schema.org/schema",
  "$id": "PromptKitScrollButtonSchema",
  "title": "Add the scroll-button component",
  "type": "object",
  "properties": {
    "project": {
      "type": "string",
      "description": "The Angular project to add the component to.",
      "$default": { "$source": "projectName" }
    },
    "path": {
      "type": "string",
      "format": "path",
      "description": "Path inside the project's sourceRoot. Defaults to app/components/prompt-kit.",
      "visible": false
    }
  },
  "required": []
}
